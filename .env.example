# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Vector DB
PINECONE_API_KEY=your_pincone_key_here
PINECONE_INDEX_NAME=marketmind

# Databases
POSTGRES_URL=postgresql://user:password@localhost:5432/marketmind
MONGODB_URL=mongodb://localhost:27017/marketmind

# Observability
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=marketmind

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
